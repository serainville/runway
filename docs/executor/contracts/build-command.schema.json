{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runway.local/schemas/executor/build-command.schema.json",
  "title": "Runway Build Command",
  "description": "Command payload dispatched from Runway control plane to executor service.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "command_id",
    "build_id",
    "attempt",
    "tenant",
    "source",
    "runtime",
    "builder",
    "steps",
    "artifact",
    "callback"
  ],
  "properties": {
    "command_id": {
      "type": "string",
      "minLength": 8
    },
    "build_id": {
      "type": "integer",
      "minimum": 1
    },
    "attempt": {
      "type": "integer",
      "minimum": 1
    },
    "tenant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "project_id", "application_id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "project_id": { "type": "integer", "minimum": 1 },
        "application_id": { "type": "integer", "minimum": 1 }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "repo_url", "commit_sha", "ref"],
      "properties": {
        "provider": { "type": "string", "enum": ["gitlab"] },
        "repo_url": { "type": "string", "format": "uri" },
        "commit_sha": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{7,64}$"
        },
        "ref": { "type": "string", "minLength": 1 }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "builder": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image", "pull_policy"],
      "properties": {
        "image": { "type": "string", "minLength": 1 },
        "pull_policy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "command", "timeout_seconds"],
        "properties": {
          "name": {
            "type": "string",
            "enum": ["lint", "test", "build"]
          },
          "command": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "timeout_seconds": {
            "type": "integer",
            "minimum": 1,
            "maximum": 86400
          }
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["registry", "repository", "tag"],
      "properties": {
        "registry": { "type": "string", "minLength": 1 },
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string", "minLength": 1 }
      }
    },
    "callback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "auth"],
      "properties": {
        "url": { "type": "string", "format": "uri" },
        "auth": {
          "type": "object",
          "additionalProperties": false,
          "required": ["scheme", "key_id"],
          "properties": {
            "scheme": { "type": "string", "enum": ["hmac"] },
            "key_id": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requested_by": { "type": "string", "minLength": 1 },
        "requested_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}

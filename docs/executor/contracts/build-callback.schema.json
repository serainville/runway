{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runway.local/schemas/executor/build-callback.schema.json",
  "title": "Executor Build Callback",
  "description": "Callback payload emitted by executor to Runway control plane.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "command_id",
    "executor_job_id",
    "build_id",
    "event_type",
    "event_time"
  ],
  "properties": {
    "command_id": {
      "type": "string",
      "minLength": 8
    },
    "executor_job_id": {
      "type": "string",
      "minLength": 8
    },
    "build_id": {
      "type": "integer",
      "minimum": 1
    },
    "event_type": {
      "type": "string",
      "enum": ["step.updated", "build.completed"]
    },
    "event_time": {
      "type": "string",
      "format": "date-time"
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "status", "attempt"],
      "properties": {
        "name": {
          "type": "string",
          "enum": ["lint", "test", "build"]
        },
        "status": {
          "type": "string",
          "enum": ["pending", "running", "succeeded", "failed", "cancelled"]
        },
        "attempt": { "type": "integer", "minimum": 1 },
        "started_at": { "type": ["string", "null"], "format": "date-time" },
        "finished_at": { "type": ["string", "null"], "format": "date-time" },
        "exit_code": { "type": ["integer", "null"] },
        "failure_code": { "type": ["string", "null"] },
        "message": { "type": ["string", "null"] }
      }
    },
    "logs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sequence", "stream", "message"],
        "properties": {
          "sequence": { "type": "integer", "minimum": 1 },
          "stream": { "type": "string", "enum": ["stdout", "stderr"] },
          "message": { "type": "string", "minLength": 1, "maxLength": 16384 }
        }
      }
    },
    "diagnostics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "backend": { "type": "string", "enum": ["docker", "kubernetes"] },
        "backend_ref": { "type": "string" }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "steps"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["succeeded", "failed", "cancelled"]
        },
        "artifact_ref": { "type": ["string", "null"] },
        "failure_code": { "type": ["string", "null"] },
        "message": { "type": ["string", "null"] },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "status"],
            "properties": {
              "name": { "type": "string", "enum": ["lint", "test", "build"] },
              "status": {
                "type": "string",
                "enum": ["pending", "running", "succeeded", "failed", "cancelled"]
              }
            }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "event_type": { "const": "step.updated" } }
      },
      "then": {
        "required": ["step"]
      }
    },
    {
      "if": {
        "properties": { "event_type": { "const": "build.completed" } }
      },
      "then": {
        "required": ["result"]
      }
    }
  ]
}

<div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm dark:border-white/10 dark:bg-slate-900/70">
  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 text-sm">
    <div>
      <div class="text-slate-500 dark:text-slate-400">Provider</div>
      <div class="mt-1 font-medium text-slate-900 dark:text-white"><%= repository_connection.provider %></div>
    </div>
    <div>
      <div class="text-slate-500 dark:text-slate-400">Validation</div>
      <div class="mt-1 font-medium text-slate-900 dark:text-white"><%= repository_connection.validation_status %></div>
    </div>
    <div>
      <div class="text-slate-500 dark:text-slate-400">Auth secret</div>
      <div class="mt-1"><input type="password" value="********" disabled class="w-24 rounded-lg border border-slate-300 bg-slate-100 px-2 py-1 text-xs text-slate-500 dark:border-white/10 dark:bg-slate-900/70 dark:text-slate-300"></div>
    </div>
    <div class="sm:col-span-2 lg:col-span-3">
      <div class="text-slate-500 dark:text-slate-400">Endpoint</div>
      <div class="mt-1 break-all font-medium text-slate-900 dark:text-white"><%= repository_connection.endpoint_url %></div>
    </div>
  </div>
</div>

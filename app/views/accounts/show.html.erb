<section class="mx-auto max-w-3xl rounded-3xl border border-slate-200 bg-white p-8 shadow-sm dark:border-white/10 dark:bg-slate-900/70">
  <div class="mb-8">
    <span class="inline-flex rounded-full border border-fuchsia-200 bg-fuchsia-100 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-700 dark:border-fuchsia-400/20 dark:bg-fuchsia-500/10 dark:text-fuchsia-200">Account</span>
    <h1 class="mt-4 text-4xl font-semibold tracking-tight text-slate-900 dark:text-white">My account</h1>
    <p class="mt-3 text-slate-600 dark:text-slate-300">Your signed-in profile for Runway.</p>
  </div>

  <div class="grid gap-4 sm:grid-cols-2">
    <div class="rounded-2xl bg-slate-100 p-4 dark:bg-slate-950/70">
      <div class="text-sm text-slate-500 dark:text-slate-400">Name</div>
      <div class="mt-1 font-medium text-slate-900 dark:text-white"><%= current_user.name %></div>
    </div>

    <div class="rounded-2xl bg-slate-100 p-4 dark:bg-slate-950/70">
      <div class="text-sm text-slate-500 dark:text-slate-400">Email</div>
      <div class="mt-1 font-medium text-slate-900 dark:text-white"><%= current_user.email %></div>
    </div>
  </div>

  <div class="mt-8 rounded-2xl border border-slate-200 bg-slate-50 p-6 dark:border-white/10 dark:bg-slate-950/50">
    <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Change password</h2>
    <p class="mt-1 text-sm text-slate-600 dark:text-slate-300">Use your current password to set a new one.</p>

    <%= form_with url: account_password_path, method: :patch, local: true, class: "mt-4 space-y-4" do |form| %>
      <div>
        <%= form.label :current_password, "Current password", class: "mb-1 block text-sm text-slate-700 dark:text-slate-300" %>
        <%= form.password_field :current_password, name: "account[current_password]", required: true, autocomplete: "current-password", class: "w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-slate-900 outline-none ring-fuchsia-500 focus:ring-2 dark:border-white/10 dark:bg-slate-900 dark:text-white" %>
      </div>

      <div>
        <%= form.label :password, "New password", class: "mb-1 block text-sm text-slate-700 dark:text-slate-300" %>
        <%= form.password_field :password, name: "account[password]", required: true, autocomplete: "new-password", class: "w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-slate-900 outline-none ring-fuchsia-500 focus:ring-2 dark:border-white/10 dark:bg-slate-900 dark:text-white" %>
      </div>

      <div>
        <%= form.label :password_confirmation, "Confirm new password", class: "mb-1 block text-sm text-slate-700 dark:text-slate-300" %>
        <%= form.password_field :password_confirmation, name: "account[password_confirmation]", required: true, autocomplete: "new-password", class: "w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-slate-900 outline-none ring-fuchsia-500 focus:ring-2 dark:border-white/10 dark:bg-slate-900 dark:text-white" %>
      </div>

      <%= form.submit "Update password", class: "inline-flex items-center rounded-full bg-fuchsia-600 px-5 py-2 text-sm font-medium text-white shadow-sm transition hover:bg-fuchsia-500" %>
    <% end %>
  </div>
</section>

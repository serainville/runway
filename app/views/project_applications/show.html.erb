<section class="space-y-8">
        <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm dark:border-white/10 dark:bg-slate-900/70"
          data-controller="auto-refresh"
          data-auto-refresh-enabled-value="<%= @recent_builds.any? { |build| %w[pending running].include?(build.status) } %>"
          data-auto-refresh-interval-value="5000">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div>
        <span class="inline-flex rounded-full border border-fuchsia-200 bg-fuchsia-100 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-700 dark:border-fuchsia-400/20 dark:bg-fuchsia-500/10 dark:text-fuchsia-200">Application</span>
        <h1 class="mt-4 text-4xl font-semibold tracking-tight text-slate-900 dark:text-white"><%= @application.name %></h1>
        <p class="mt-3 max-w-3xl text-base leading-7 text-slate-600 dark:text-slate-300"><%= @application.description %></p>
      </div>

      <%= button_to "Start build",
                    start_build_project_application_path(@project, @application),
                    method: :post,
                    params: { source_ref: "main" },
                    class: "rounded-full bg-fuchsia-600 px-5 py-2 text-sm font-medium text-white transition hover:bg-fuchsia-500" %>

      <span class="inline-flex rounded-full border px-3 py-1 text-xs font-medium <%= application_state_badge_classes(@application) %>"><%= application_state(@application) %></span>
    </div>

    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <div class="rounded-2xl bg-slate-100 p-4 dark:bg-slate-950/70">
        <div class="text-sm text-slate-500 dark:text-slate-400">Runtime</div>
        <div class="mt-1 font-medium text-slate-900 dark:text-white"><%= application_runtime_with_icon(@application) %></div>
      </div>
      <div class="rounded-2xl bg-slate-100 p-4 dark:bg-slate-950/70">
        <div class="text-sm text-slate-500 dark:text-slate-400">Project</div>
        <div class="mt-1 font-medium text-slate-900 dark:text-white"><%= @project.name %></div>
      </div>
      <div class="rounded-2xl bg-slate-100 p-4 dark:bg-slate-950/70">
        <div class="text-sm text-slate-500 dark:text-slate-400">Environments</div>
        <div class="mt-1 font-medium text-slate-900 dark:text-white"><%= pluralize(@application.environments.count, "environment") %></div>
      </div>
    </div>
  </div>

  <% if @application.repository_connection %>
    <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm dark:border-white/10 dark:bg-slate-900/70">
      <h2 class="text-xl font-semibold text-slate-900 dark:text-white">Repository</h2>
      <div class="mt-4 grid gap-4 text-sm sm:grid-cols-3">
        <div>
          <div class="text-slate-500 dark:text-slate-400">Provider</div>
          <div class="mt-1 font-medium text-slate-900 dark:text-white"><%= @application.repository_connection.provider %></div>
        </div>
        <div>
          <div class="text-slate-500 dark:text-slate-400">URL</div>
          <div class="mt-1 break-all font-medium text-slate-900 dark:text-white"><%= @application.repository_url %></div>
        </div>
        <div>
          <div class="text-slate-500 dark:text-slate-400">Connection endpoint</div>
          <div class="mt-1 break-all font-medium text-slate-900 dark:text-white"><%= @application.repository_connection.endpoint_url %></div>
        </div>
        <div>
          <div class="text-slate-500 dark:text-slate-400">Current commit hash</div>
          <div class="mt-1 break-all font-mono font-medium text-slate-900 dark:text-white"><%= @current_commit_sha.presence || "Not available yet" %></div>
        </div>
      </div>
    </div>
  <% end %>

  <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm dark:border-white/10 dark:bg-slate-900/70">
    <div class="flex items-center justify-between gap-4">
      <h2 class="text-xl font-semibold text-slate-900 dark:text-white">Build history</h2>
      <% if (latest_build = @recent_builds.first) %>
        <span class="rounded-full border px-3 py-1 text-xs font-medium <%= build_status_badge_classes(latest_build.status) %>">
          Latest: <%= build_status_with_icon(latest_build.status) %>
        </span>
      <% end %>
    </div>
    <p class="mt-2 text-xs text-slate-500 dark:text-slate-400" data-auto-refresh-target="label"></p>

    <% if @recent_builds.any? %>
      <div class="mt-4 overflow-hidden rounded-2xl border border-slate-200 dark:border-white/10">
        <table class="min-w-full divide-y divide-slate-200 text-left text-sm dark:divide-white/10">
          <thead class="bg-slate-50 dark:bg-white/5">
            <tr>
              <th class="px-4 py-3">Build</th>
              <th class="px-4 py-3">Status</th>
              <th class="px-4 py-3">Source</th>
              <th class="px-4 py-3">Requested by</th>
              <th class="px-4 py-3">Requested at</th>
              <th class="px-4 py-3">Action</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-200 dark:divide-white/10">
            <% @recent_builds.each do |build| %>
              <tr>
                <td class="px-4 py-3 font-medium text-slate-900 dark:text-white">
                  <%= link_to "##{build.id}", project_application_build_path(@project, @application, build), class: "underline decoration-dotted underline-offset-2" %>
                </td>
                <td class="px-4 py-3">
                  <span class="rounded-full border px-2.5 py-1 text-xs font-medium <%= build_status_badge_classes(build.status) %>"><%= build_status_with_icon(build.status) %></span>
                </td>
                <td class="px-4 py-3 text-slate-700 dark:text-slate-300"><%= build.source_ref %>@<%= build.commit_sha %></td>
                <td class="px-4 py-3 text-slate-700 dark:text-slate-300"><%= build.requested_by.username %></td>
                <td class="px-4 py-3 text-slate-700 dark:text-slate-300"><%= build.created_at.strftime("%Y-%m-%d %H:%M:%S") %></td>
                <td class="px-4 py-3 text-slate-700 dark:text-slate-300">
                  <div class="flex items-center gap-2">
                    <%= link_to "Build details", project_application_build_path(@project, @application, build), class: "rounded-full bg-slate-100 px-3 py-1 text-xs font-medium dark:bg-slate-800" %>
                    <% if %w[pending running].include?(build.status) %>
                      <%= button_to "Cancel",
                                    cancel_project_application_build_path(@project, @application, build),
                                    method: :patch,
                                    form: { data: { turbo_confirm: "Cancel this running build?" } },
                                    class: "rounded-full bg-rose-600 px-3 py-1 text-xs font-medium text-white transition hover:bg-rose-500" %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="mt-4 text-sm text-slate-600 dark:text-slate-300">No builds yet. Start a build to see status updates here.</p>
    <% end %>
  </div>

  <% if @application.environments.any? %>
    <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm dark:border-white/10 dark:bg-slate-900/70">
      <h2 class="text-xl font-semibold text-slate-900 dark:text-white">Environments</h2>
      <div class="mt-4 grid gap-4 md:grid-cols-2">
        <% @application.environments.order(:name).each do |environment| %>
          <%= link_to project_application_environment_path(@project, @application, environment), class: "rounded-2xl border border-slate-200 bg-slate-50 p-5 transition hover:border-fuchsia-300 hover:bg-fuchsia-50 dark:border-white/10 dark:bg-slate-950/70 dark:hover:border-fuchsia-400/30 dark:hover:bg-slate-900" do %>
            <div class="flex items-start justify-between gap-3">
              <div>
                <div class="font-semibold text-slate-900 dark:text-white"><%= environment.name %></div>
                <div class="mt-1 text-sm text-slate-500 dark:text-slate-400"><%= environment.deployment_target.name %></div>
              </div>
              <% if environment.default? %>
                <span class="rounded-full border border-emerald-300 bg-emerald-100 px-3 py-1 text-xs font-medium text-emerald-700 dark:border-emerald-400/20 dark:bg-emerald-500/10 dark:text-emerald-200">default</span>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
</section>

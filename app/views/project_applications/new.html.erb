<section class="mx-auto max-w-3xl rounded-3xl border border-slate-200 bg-white p-8 shadow-sm dark:border-white/10 dark:bg-slate-900/70">
  <div class="mb-8">
    <span class="inline-flex rounded-full border border-fuchsia-200 bg-fuchsia-100 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-700 dark:border-fuchsia-400/20 dark:bg-fuchsia-500/10 dark:text-fuchsia-200">Application</span>
    <h1 class="mt-4 text-4xl font-semibold tracking-tight text-slate-900 dark:text-white">Define application in <%= @project.name %></h1>
    <p class="mt-3 text-slate-600 dark:text-slate-300">Create an app inside this project and connect it to a repository.</p>
  </div>

  <%= form_with model: @application, url: project_applications_path(@project), local: true, class: "space-y-6" do |form| %>
    <div class="grid gap-6 sm:grid-cols-2">
      <div>
        <%= form.label :name, class: "mb-2 block text-sm font-medium text-slate-700 dark:text-slate-200" %>
        <%= form.text_field :name, required: true, class: "w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 placeholder:text-slate-400 focus:border-fuchsia-400 focus:outline-none focus:ring-2 focus:ring-fuchsia-400/20 dark:border-white/10 dark:bg-slate-950/60 dark:text-white dark:placeholder:text-slate-500" %>
      </div>

      <div>
        <%= label_tag "application_runtime_key", "Runtime", class: "mb-2 block text-sm font-medium text-slate-700 dark:text-slate-200" %>
        <%= select_tag "application[runtime_key]",
                       options_for_select(@runtime_options.map { |option| [option.display_name, option.key] }, @selected_runtime_key),
                       prompt: "Select a supported runtime",
                       required: true,
                       class: "w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 focus:border-fuchsia-400 focus:outline-none focus:ring-2 focus:ring-fuchsia-400/20 dark:border-white/10 dark:bg-slate-950/60 dark:text-white" %>
      </div>
    </div>

    <div>
      <%= form.label :description, class: "mb-2 block text-sm font-medium text-slate-700 dark:text-slate-200" %>
      <%= form.text_area :description, rows: 4, class: "w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 placeholder:text-slate-400 focus:border-fuchsia-400 focus:outline-none focus:ring-2 focus:ring-fuchsia-400/20 dark:border-white/10 dark:bg-slate-950/60 dark:text-white dark:placeholder:text-slate-500" %>
    </div>

    <div class="grid gap-6 sm:grid-cols-2">
      <div>
        <%= form.label :repository_url, "Repository URL", class: "mb-2 block text-sm font-medium text-slate-700 dark:text-slate-200" %>
        <%= form.url_field :repository_url, value: @repository_url, required: true, class: "w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 focus:border-fuchsia-400 focus:outline-none focus:ring-2 focus:ring-fuchsia-400/20 dark:border-white/10 dark:bg-slate-950/60 dark:text-white" %>
      </div>
      <div>
        <%= form.label :repository_connection_id, "Repository connection", class: "mb-2 block text-sm font-medium text-slate-700 dark:text-slate-200" %>
        <%= form.select :repository_connection_id,
                        options_for_select(@repository_connections.map { |connection| [connection.selection_label, connection.id] }, @selected_repository_connection_id),
                        { prompt: "Select a repository connection or derive from URL" },
                        class: "w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 focus:border-fuchsia-400 focus:outline-none focus:ring-2 focus:ring-fuchsia-400/20 dark:border-white/10 dark:bg-slate-950/60 dark:text-white" %>
      </div>
    </div>

    <div class="rounded-2xl border border-dashed border-slate-300 bg-slate-50 px-4 py-3 text-sm text-slate-600 dark:border-white/10 dark:bg-slate-950/50 dark:text-slate-300">
      Select a shared or project-local repository connection for authentication, or leave it blank to derive one from the repository URL when exactly one endpoint matches.
    </div>

    <div class="flex flex-wrap gap-3 pt-2">
      <%= form.submit "Create application", class: "rounded-full bg-fuchsia-600 px-5 py-2.5 text-sm font-medium text-white transition hover:bg-fuchsia-500" %>
      <%= link_to "Back to project", project_path(@project), class: "rounded-full border border-slate-300 px-5 py-2.5 text-sm font-medium text-slate-700 transition hover:bg-slate-100 dark:border-white/10 dark:text-slate-200 dark:hover:bg-white/10" %>
    </div>
  <% end %>
</section>

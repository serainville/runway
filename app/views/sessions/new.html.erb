<main class="container">
  <h1>Sign in</h1>

  <%= form_with scope: :session, url: session_path, local: true do |form| %>
    <div>
      <%= form.label :username %>
      <%= form.text_field :username, required: true, autocomplete: "username" %>
    </div>

    <div>
      <%= form.label :password %>
      <%= form.password_field :password, required: true, autocomplete: "current-password" %>
    </div>

    <div>
      <%= form.submit "Sign in" %>
    </div>
  <% end %>
</main>

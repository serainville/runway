<section class="mx-auto max-w-3xl rounded-3xl border border-slate-200 bg-white p-8 shadow-sm dark:border-white/10 dark:bg-slate-900/70">
  <div class="mb-8">
    <span class="inline-flex rounded-full border border-fuchsia-200 bg-fuchsia-100 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-700 dark:border-fuchsia-400/20 dark:bg-fuchsia-500/10 dark:text-fuchsia-200">Welcome back</span>
    <h1 class="mt-4 text-4xl font-semibold tracking-tight text-slate-900 dark:text-white">Sign in to Runway</h1>
    <p class="mt-3 text-slate-600 dark:text-slate-300">Access your projects, builds, and deployments.</p>
  </div>

  <%= form_with scope: :session, url: session_path, local: true, class: "space-y-6" do |form| %>
    <div>
      <%= form.label :username, class: "mb-2 block text-sm font-medium text-slate-700 dark:text-slate-200" %>
      <%= form.text_field :username, required: true, autocomplete: "username", class: "w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 placeholder:text-slate-400 focus:border-fuchsia-400 focus:outline-none focus:ring-2 focus:ring-fuchsia-400/20 dark:border-white/10 dark:bg-slate-950/60 dark:text-white dark:placeholder:text-slate-500" %>
    </div>

    <div>
      <%= form.label :password, class: "mb-2 block text-sm font-medium text-slate-700 dark:text-slate-200" %>
      <%= form.password_field :password, required: true, autocomplete: "current-password", class: "w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 placeholder:text-slate-400 focus:border-fuchsia-400 focus:outline-none focus:ring-2 focus:ring-fuchsia-400/20 dark:border-white/10 dark:bg-slate-950/60 dark:text-white dark:placeholder:text-slate-500" %>
    </div>

    <div class="flex flex-wrap gap-3 pt-2">
      <%= form.submit "Sign in", class: "rounded-full bg-fuchsia-600 px-5 py-2.5 text-sm font-medium text-white transition hover:bg-fuchsia-500" %>
      <%= link_to "Create account", new_registration_path, class: "rounded-full border border-slate-300 px-5 py-2.5 text-sm font-medium text-slate-700 transition hover:bg-slate-100 dark:border-white/10 dark:text-slate-200 dark:hover:bg-white/10" %>
    </div>
  <% end %>
</section>

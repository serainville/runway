<section class="space-y-6">
  <div class="flex items-center justify-between gap-3">
    <div>
      <h1 class="text-3xl font-semibold tracking-tight text-slate-900 dark:text-white">Event details</h1>
      <p class="mt-2 text-slate-600 dark:text-slate-300">Detailed information for the selected application event.</p>
    </div>
    <%= link_to "Back to application", project_application_path(@project, @application), class: "rounded-full border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 dark:border-white/10 dark:text-slate-200" %>
  </div>

  <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm dark:border-white/10 dark:bg-slate-900/70">
    <div class="grid gap-4 text-sm sm:grid-cols-2">
      <div>
        <div class="text-slate-500 dark:text-slate-400">Title</div>
        <div class="mt-1 font-medium text-slate-900 dark:text-white"><%= @event.title %></div>
      </div>
      <div>
        <div class="text-slate-500 dark:text-slate-400">Triggered by</div>
        <div class="mt-1 font-medium text-slate-900 dark:text-white"><%= @event.triggered_by %></div>
      </div>
      <div>
        <div class="text-slate-500 dark:text-slate-400">When</div>
        <div class="mt-1 font-medium text-slate-900 dark:text-white"><%= @event.occurred_at.strftime("%Y-%m-%d %H:%M:%S") %></div>
      </div>
      <div>
        <div class="text-slate-500 dark:text-slate-400">Category</div>
        <div class="mt-1 font-medium text-slate-900 dark:text-white"><%= @event.category.humanize %></div>
      </div>
    </div>

    <div class="mt-6 border-t border-slate-200 pt-6 dark:border-white/10">
      <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Details</h2>
      <p class="mt-2 text-sm text-slate-700 dark:text-slate-300"><%= @event.detail %></p>

      <h3 class="mt-4 text-sm font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">Metadata</h3>
      <pre class="mt-2 overflow-auto rounded-xl bg-slate-100 p-4 text-xs text-slate-700 dark:bg-slate-950/70 dark:text-slate-300"><%= JSON.pretty_generate(@event.metadata || {}) %></pre>
    </div>
  </div>
</section>

<section class="space-y-8">
  <div>
    <h1 class="text-3xl font-semibold tracking-tight text-slate-900 dark:text-white">Build Settings</h1>
    <p class="mt-2 text-slate-600 dark:text-slate-300">Manage Docker host registrations used for running build workloads.</p>
  </div>

  <%= render "build_settings_nav" %>

  <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm dark:border-white/10 dark:bg-slate-900/70">
    <h2 class="text-lg font-semibold">Add Docker host registration</h2>
    <%= form_with model: [:admin, @build_integration], url: admin_build_integrations_path, scope: :build_integration, local: true, class: "mt-4 grid gap-3 sm:grid-cols-2" do |form| %>
      <%= form.hidden_field :integration_type, value: "docker_host" %>
      <%= form.text_field :name, placeholder: "Name", required: true, class: "rounded-xl border border-slate-300 bg-white px-3 py-2 dark:border-white/10 dark:bg-slate-950/60" %>
      <%= form.text_field :endpoint, placeholder: "Docker host endpoint", required: true, class: "rounded-xl border border-slate-300 bg-white px-3 py-2 dark:border-white/10 dark:bg-slate-950/60" %>
      <%= form.text_field :credential_reference, placeholder: "Credential reference", class: "rounded-xl border border-slate-300 bg-white px-3 py-2 dark:border-white/10 dark:bg-slate-950/60" %>
      <%= form.text_field :validation_status, placeholder: "Validation status", value: "pending", class: "rounded-xl border border-slate-300 bg-white px-3 py-2 dark:border-white/10 dark:bg-slate-950/60" %>
      <label class="inline-flex items-center gap-2 text-sm">
        <%= form.check_box :active %>
        Active
      </label>
      <label class="inline-flex items-center gap-2 text-sm">
        <%= form.check_box :default %>
        Default build host
      </label>
      <%= form.text_area :ca_bundle_reference, placeholder: "CA bundle", rows: 4, class: "sm:col-span-2 rounded-xl border border-slate-300 bg-white px-3 py-2 dark:border-white/10 dark:bg-slate-950/60" %>
      <%= form.text_field :description, placeholder: "Description", class: "sm:col-span-2 rounded-xl border border-slate-300 bg-white px-3 py-2 dark:border-white/10 dark:bg-slate-950/60" %>
      <div class="sm:col-span-2">
        <%= form.submit "Add Docker host", class: "rounded-full bg-fuchsia-600 px-5 py-2 text-sm font-medium text-white" %>
      </div>
    <% end %>
  </div>

  <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm dark:border-white/10 dark:bg-slate-900/70">
    <table class="min-w-full divide-y divide-slate-200 text-left text-sm dark:divide-white/10">
      <thead class="bg-slate-50 dark:bg-white/5">
        <tr>
          <th class="px-4 py-3">Name</th>
          <th class="px-4 py-3">Endpoint</th>
          <th class="px-4 py-3">Validation</th>
          <th class="px-4 py-3">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-200 dark:divide-white/10">
        <% @build_integrations.each do |integration| %>
          <tr>
            <td class="px-4 py-3"><%= integration.name %></td>
            <td class="px-4 py-3"><%= integration.endpoint %></td>
            <td class="px-4 py-3"><%= integration.validation_status %></td>
            <td class="px-4 py-3">
              <div class="flex flex-wrap items-center gap-2">
                <%= form_with model: [:admin, integration], url: admin_build_integration_path(integration), scope: :build_integration, method: :patch, local: true, class: "flex flex-wrap items-center gap-2" do |form| %>
                  <%= form.hidden_field :integration_type, value: "docker_host" %>
                  <%= form.text_field :endpoint, class: "rounded-lg border border-slate-300 bg-white px-2 py-1 dark:border-white/10 dark:bg-slate-950/60" %>
                  <%= form.text_field :credential_reference, placeholder: "Credential reference", class: "rounded-lg border border-slate-300 bg-white px-2 py-1 dark:border-white/10 dark:bg-slate-950/60" %>
                  <%= form.text_field :validation_status, placeholder: "Validation status", class: "rounded-lg border border-slate-300 bg-white px-2 py-1 dark:border-white/10 dark:bg-slate-950/60" %>
                  <label class="inline-flex items-center gap-1 text-xs">
                    <%= form.check_box :active %>
                    Active
                  </label>
                  <label class="inline-flex items-center gap-1 text-xs">
                    <%= form.check_box :default %>
                    Default
                  </label>
                  <%= form.text_area :ca_bundle_reference, placeholder: "CA bundle", rows: 3, class: "rounded-lg border border-slate-300 bg-white px-2 py-1 dark:border-white/10 dark:bg-slate-950/60" %>
                  <%= form.submit "Update", class: "rounded-full bg-fuchsia-600 px-3 py-1 text-xs font-medium text-white" %>
                <% end %>
                <%= button_to "Validate", validate_connection_admin_build_integration_path(integration), method: :patch, class: "rounded-full bg-slate-800 px-3 py-1 text-xs font-medium text-white dark:bg-slate-200 dark:text-slate-900" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>

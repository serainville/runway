<section class="space-y-8"
         data-controller="auto-refresh"
         data-auto-refresh-enabled-value="<%= @build_integrations.any? %>"
         data-auto-refresh-interval-value="15000"
         data-auto-refresh-frame-id-value="executor_registrations_table"
         data-auto-refresh-frame-path-value="<%= executors_admin_build_integrations_path(table_only: 1) %>">
  <div>
    <h1 class="text-3xl font-semibold tracking-tight text-slate-900 dark:text-white">Build Settings</h1>
    <p class="mt-2 text-slate-600 dark:text-slate-300">Manage executor service registrations used for command-mode execution callbacks.</p>
    <p class="mt-1 text-xs text-slate-500 dark:text-slate-400" data-auto-refresh-target="label"></p>
  </div>

  <%= render "build_settings_nav" %>

  <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm dark:border-white/10 dark:bg-slate-900/70">
    <h2 class="text-lg font-semibold">Add executor registration</h2>
    <%= form_with model: [:admin, @build_integration], url: admin_build_integrations_path, scope: :build_integration, local: true, class: "mt-4 grid gap-3 sm:grid-cols-2" do |form| %>
      <%= form.hidden_field :integration_type, value: "executor_registration" %>
      <%= form.text_field :name, placeholder: "Name", required: true, class: "rounded-xl border border-slate-300 bg-white px-3 py-2 dark:border-white/10 dark:bg-slate-950/60" %>
      <%= form.text_field :endpoint, placeholder: "Executor API endpoint", required: true, class: "rounded-xl border border-slate-300 bg-white px-3 py-2 dark:border-white/10 dark:bg-slate-950/60" %>
      <%= form.text_field :credential_reference, placeholder: "Credential reference", class: "rounded-xl border border-slate-300 bg-white px-3 py-2 dark:border-white/10 dark:bg-slate-950/60" %>
      <%= form.text_area :ca_bundle_reference, placeholder: "CA bundle", rows: 4, class: "rounded-xl border border-slate-300 bg-white px-3 py-2 dark:border-white/10 dark:bg-slate-950/60" %>
      <label class="inline-flex items-center gap-2 text-sm sm:col-span-2">
        <%= form.check_box :active %>
        Active
      </label>
      <%= form.text_field :description, placeholder: "Description", class: "sm:col-span-2 rounded-xl border border-slate-300 bg-white px-3 py-2 dark:border-white/10 dark:bg-slate-950/60" %>
      <div class="sm:col-span-2">
        <%= form.submit "Add executor registration", class: "rounded-full bg-fuchsia-600 px-5 py-2 text-sm font-medium text-white" %>
      </div>
    <% end %>
  </div>

  <%= render "executors_table_frame" %>
</section>

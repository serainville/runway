<section class="space-y-6">
  <div>
    <h1 class="text-3xl font-semibold tracking-tight text-slate-900 dark:text-white">Admin Project Applications</h1>
    <p class="mt-2 text-slate-600 dark:text-slate-300">Manage application metadata for platform operations.</p>
  </div>

  <div class="space-y-4">
    <% @applications.each do |application| %>
      <article class="rounded-2xl border border-slate-200 bg-white p-4 dark:border-white/10 dark:bg-slate-900/70">
        <p class="font-medium text-slate-900 dark:text-white"><%= application.name %></p>
        <p class="text-xs text-slate-500 dark:text-slate-400">Project: <%= application.project&.name || "(none)" %></p>
        <%= form_with model: [:admin, application], url: admin_project_application_path(application), local: true, class: "mt-3 flex flex-col gap-2" do |form| %>
          <%= form.text_area :description, rows: 2, class: "w-full rounded-xl border border-slate-300 bg-white px-3 py-2 dark:border-white/10 dark:bg-slate-950/60" %>
          <div>
            <%= form.submit "Save", class: "rounded-full bg-fuchsia-600 px-4 py-1.5 text-sm font-medium text-white" %>
          </div>
        <% end %>
      </article>
    <% end %>
  </div>
</section>

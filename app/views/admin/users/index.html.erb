<section class="space-y-6">
  <div>
    <h1 class="text-3xl font-semibold tracking-tight text-slate-900 dark:text-white">Users</h1>
    <p class="mt-2 text-slate-600 dark:text-slate-300">Manage account roles for Runway operations.</p>
  </div>

  <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm dark:border-white/10 dark:bg-slate-900/70">
    <table class="min-w-full divide-y divide-slate-200 text-left text-sm dark:divide-white/10">
      <thead class="bg-slate-50 dark:bg-white/5">
        <tr>
          <th class="px-4 py-3">Email</th>
          <th class="px-4 py-3">Name</th>
          <th class="px-4 py-3">Role</th>
          <th class="px-4 py-3">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-200 dark:divide-white/10">
        <% @users.each do |user| %>
          <tr>
            <td class="px-4 py-3"><%= user.email %></td>
            <td class="px-4 py-3"><%= user.name %></td>
            <td class="px-4 py-3">
              <%= form_with model: [:admin, user], local: true, class: "flex items-center gap-2" do |form| %>
                <%= form.select :role, User::ROLES.map { |role| [role.titleize, role] }, {}, class: "rounded-xl border border-slate-300 bg-white px-3 py-2 dark:border-white/10 dark:bg-slate-950/60" %>
                <%= form.submit "Save", class: "rounded-full bg-fuchsia-600 px-3 py-1.5 text-xs font-medium text-white" %>
              <% end %>
            </td>
            <td class="px-4 py-3">
              <%= form_with url: reset_password_admin_user_path(user), method: :patch, local: true, class: "flex flex-wrap items-center gap-2" do |form| %>
                <%= form.password_field :password, name: "password_reset[password]", required: true, placeholder: "New password", autocomplete: "new-password", class: "w-40 rounded-xl border border-slate-300 bg-white px-3 py-2 text-xs dark:border-white/10 dark:bg-slate-950/60" %>
                <%= form.password_field :password_confirmation, name: "password_reset[password_confirmation]", required: true, placeholder: "Confirm", autocomplete: "new-password", class: "w-40 rounded-xl border border-slate-300 bg-white px-3 py-2 text-xs dark:border-white/10 dark:bg-slate-950/60" %>
                <%= form.submit "Reset password", class: "rounded-full bg-slate-800 px-3 py-1.5 text-xs font-medium text-white dark:bg-slate-200 dark:text-slate-900" %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>

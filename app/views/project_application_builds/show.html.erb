<section class="space-y-6"
         data-controller="auto-refresh"
         data-auto-refresh-enabled-value="<%= !@build.terminal? %>"
         data-auto-refresh-interval-value="5000">
  <div>
    <h1 class="text-3xl font-semibold tracking-tight text-slate-900 dark:text-white">Build details</h1>
    <p class="mt-2 text-slate-600 dark:text-slate-300"><%= @application.name %> in <%= @project.name %></p>
    <% if %w[pending running].include?(@build.status) %>
      <div class="mt-3">
        <%= button_to "Cancel build",
                      cancel_project_application_build_path(@project, @application, @build),
                      method: :patch,
                      form: { data: { turbo_confirm: "Cancel this running build?" } },
                      class: "rounded-full bg-rose-600 px-4 py-2 text-sm font-medium text-white transition hover:bg-rose-500" %>
      </div>
    <% end %>
  </div>

  <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm dark:border-white/10 dark:bg-slate-900/70">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 text-sm">
      <div><span class="text-slate-500 dark:text-slate-400">Build</span><p class="font-medium text-slate-900 dark:text-white">#<%= @build.id %></p></div>
      <div><span class="text-slate-500 dark:text-slate-400">Status</span><p class="font-medium text-slate-900 dark:text-white"><%= build_status_with_icon(@build.status) %></p></div>
      <div><span class="text-slate-500 dark:text-slate-400">Commit</span><p class="font-mono font-medium text-slate-900 dark:text-white"><%= @build.commit_sha %></p></div>
      <div><span class="text-slate-500 dark:text-slate-400">Runtime container</span><p class="font-mono font-medium text-slate-900 dark:text-white"><%= @build.runtime_container_id.presence || "Not available" %></p></div>
      <div><span class="text-slate-500 dark:text-slate-400">Container runtime status</span><p class="font-medium text-slate-900 dark:text-white"><%= @build.runtime_status.presence || "Unknown" %></p></div>
      <div><span class="text-slate-500 dark:text-slate-400">Requested by</span><p class="font-medium text-slate-900 dark:text-white"><%= @build.requested_by.username %></p></div>
      <div><span class="text-slate-500 dark:text-slate-400">Container repository URL</span><p class="font-mono font-medium text-slate-900 dark:text-white"><%= @build.container_repository_url.presence || "Not available" %></p></div>
      <div><span class="text-slate-500 dark:text-slate-400">Container image name</span><p class="font-mono font-medium text-slate-900 dark:text-white"><%= @build.container_image_name.presence || "Not available" %></p></div>
      <div><span class="text-slate-500 dark:text-slate-400">Container tag/hash</span><p class="font-mono font-medium text-slate-900 dark:text-white"><%= @build.container_tag_or_hash.presence || "Not available" %></p></div>
    </div>
    <p class="mt-3 text-xs text-slate-500 dark:text-slate-400" data-auto-refresh-target="label"></p>
  </div>

  <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm dark:border-white/10 dark:bg-slate-900/70">
    <h2 class="text-xl font-semibold text-slate-900 dark:text-white">Build phases</h2>
    <ul class="mt-3 space-y-2 text-sm">
      <% @build.build_phase_events.order(:created_at).each do |event| %>
        <li class="rounded-xl bg-slate-50 px-3 py-2 dark:bg-slate-950/60">
          <span class="font-medium"><%= event.phase.humanize %>:</span> <%= event.status.humanize %>
          <% if event.message.present? %>
            <span class="text-slate-600 dark:text-slate-300"> - <%= event.message %></span>
          <% end %>
        </li>
      <% end %>
    </ul>
  </div>

  <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm dark:border-white/10 dark:bg-slate-900/70">
    <h2 class="text-xl font-semibold text-slate-900 dark:text-white">Build host request status</h2>
    <div class="mt-3 overflow-hidden rounded-xl border border-slate-200 dark:border-white/10">
      <table class="min-w-full divide-y divide-slate-200 text-left text-sm dark:divide-white/10">
        <thead class="bg-slate-50 dark:bg-white/5">
          <tr>
            <th class="px-3 py-2">Method</th>
            <th class="px-3 py-2">Path</th>
            <th class="px-3 py-2">Response</th>
            <th class="px-3 py-2">Duration</th>
            <th class="px-3 py-2">Result</th>
            <th class="px-3 py-2">Error details</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-200 dark:divide-white/10">
          <% @build.build_host_request_events.order(:created_at).each do |event| %>
            <tr>
              <td class="px-3 py-2 font-medium"><%= event.request_method %></td>
              <td class="px-3 py-2 font-mono"><%= event.request_path %></td>
              <td class="px-3 py-2"><%= event.response_status_code %></td>
              <td class="px-3 py-2"><%= event.duration_ms.present? ? "#{event.duration_ms}ms" : "n/a" %></td>
              <td class="px-3 py-2"><%= event.success ? "Succeeded" : "Failed" %></td>
              <td class="px-3 py-2"><%= event.error_message.presence || "-" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm dark:border-white/10 dark:bg-slate-900/70">
    <h2 class="text-xl font-semibold text-slate-900 dark:text-white">Build logs</h2>
    <% if @build.build_logs_truncated? %>
      <div class="mt-3 rounded-xl border border-amber-300 bg-amber-50 px-3 py-2 text-xs font-medium text-amber-800 dark:border-amber-500/40 dark:bg-amber-500/10 dark:text-amber-200">
        Logs were truncated due to size limits.
      </div>
    <% end %>
    <pre class="mt-3 max-h-96 overflow-auto rounded-xl bg-slate-950 p-3 text-xs text-slate-100"><%= @build.build_log_chunks.order(:phase, :sequence).map(&:chunk).join("\n") %></pre>
  </div>
</section>

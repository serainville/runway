<section class="space-y-8">
  <div class="rounded-3xl border border-slate-200 bg-white shadow-sm dark:border-white/10 dark:bg-slate-900/70">
    <div class="border-b border-slate-200 bg-gradient-to-r from-fuchsia-600 to-indigo-600 px-8 py-6 text-white dark:border-white/10">
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div>
          <span class="inline-flex rounded-full border border-white/30 bg-white/15 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-100">Project</span>
          <h1 class="mt-3 text-3xl font-semibold tracking-tight sm:text-4xl"><%= @project.name %></h1>
          <% if @project.description.present? %>
            <p class="mt-2 max-w-3xl text-sm text-fuchsia-100"><%= @project.description %></p>
          <% end %>
        </div>
        <div class="rounded-xl border border-white/30 bg-white/15 px-4 py-2 text-sm">Slug: <%= @project.slug %></div>
      </div>
    </div>

    <nav class="flex flex-wrap gap-1 border-b border-slate-200 px-6 py-3 text-sm dark:border-white/10">
      <a href="#" class="rounded-lg bg-fuchsia-100 px-3 py-1.5 font-medium text-fuchsia-700 dark:bg-fuchsia-500/15 dark:text-fuchsia-200">Overview</a>
      <a href="#" class="rounded-lg px-3 py-1.5 text-slate-500 hover:bg-slate-100 hover:text-slate-700 dark:text-slate-400 dark:hover:bg-white/10 dark:hover:text-slate-200">Applications</a>
      <a href="#" class="rounded-lg px-3 py-1.5 text-slate-500 hover:bg-slate-100 hover:text-slate-700 dark:text-slate-400 dark:hover:bg-white/10 dark:hover:text-slate-200">Activity</a>
      <% if can_manage_project_settings?(@project) %>
        <%= link_to "Settings", project_settings_path(@project), class: "rounded-lg px-3 py-1.5 text-slate-500 hover:bg-slate-100 hover:text-slate-700 dark:text-slate-400 dark:hover:bg-white/10 dark:hover:text-slate-200" %>
      <% end %>
    </nav>

    <div class="px-8 py-6">
      <div class="flex flex-wrap gap-3">
        <% if can_initiate_build_for_project?(@project) %>
          <%= link_to "Add application", new_project_application_path(@project), class: "rounded-full bg-fuchsia-600 px-5 py-2.5 text-sm font-medium text-white transition hover:bg-fuchsia-500" %>
        <% end %>
        <% if can_manage_project_settings?(@project) %>
          <%= link_to "Repository connections", project_repository_connections_path(@project), class: "rounded-full border border-slate-300 px-5 py-2.5 text-sm font-medium text-slate-700 transition hover:bg-slate-100 dark:border-white/10 dark:text-slate-200 dark:hover:bg-white/10" %>
        <% end %>
        <% if can_manage_project_members?(@project) %>
          <%= link_to "Manage members", project_memberships_path(@project), class: "rounded-full border border-slate-300 px-5 py-2.5 text-sm font-medium text-slate-700 transition hover:bg-slate-100 dark:border-white/10 dark:text-slate-200 dark:hover:bg-white/10" %>
        <% end %>
        <%= link_to "Back to dashboard", dashboard_path, class: "rounded-full border border-slate-300 px-5 py-2.5 text-sm font-medium text-slate-700 transition hover:bg-slate-100 dark:border-white/10 dark:text-slate-200 dark:hover:bg-white/10" %>
      </div>
    </div>
  </div>

  <div class="space-y-4">
    <div class="flex items-center justify-between gap-3">
      <h2 class="text-xl font-semibold text-slate-900 dark:text-white">Applications</h2>
      <p class="text-sm text-slate-500 dark:text-slate-400"><%= pluralize(@applications.size, "application") %></p>
    </div>

    <% if @applications.any? %>
      <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm dark:border-white/10 dark:bg-slate-900/70">
        <table class="min-w-full divide-y divide-slate-200 text-left text-sm dark:divide-white/10">
          <thead class="bg-slate-50 text-slate-500 dark:bg-white/5 dark:text-slate-400">
            <tr>
              <th class="px-6 py-4 font-medium">Application</th>
              <th class="px-6 py-4 font-medium">Runtime</th>
              <th class="px-6 py-4 font-medium">State</th>
              <th class="px-6 py-4 font-medium">Environment</th>
              <th class="px-6 py-4 font-medium">Updated</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-200 dark:divide-white/10">
            <% @applications.each do |application| %>
              <tr class="text-slate-700 hover:bg-slate-50 dark:text-slate-200 dark:hover:bg-white/5">
                <td class="px-6 py-4 font-medium text-slate-900 dark:text-white">
                  <%= link_to application.name, project_application_path(@project, application), class: "transition hover:text-fuchsia-700 dark:hover:text-fuchsia-200" %>
                  <% if application.description.present? %>
                    <div class="mt-1 text-xs text-slate-500 dark:text-slate-400"><%= application.description %></div>
                  <% end %>
                </td>
                <td class="px-6 py-4"><%= application_runtime_with_icon(application) %></td>
                <td class="px-6 py-4">
                  <span class="inline-flex rounded-full border px-3 py-1 text-xs font-medium <%= application_state_badge_classes(application) %>"><%= application_state(application) %></span>
                </td>
                <td class="px-6 py-4 text-slate-500 dark:text-slate-300"><%= application.environments.find_by(default: true)&.name || "—" %></td>
                <td class="px-6 py-4 text-slate-500 dark:text-slate-400"><%= time_ago_in_words(application.updated_at) %> ago</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="rounded-3xl border border-dashed border-slate-300 bg-white p-10 text-center text-slate-600 dark:border-white/20 dark:bg-slate-900/60 dark:text-slate-300">
        <p class="text-lg font-medium text-slate-900 dark:text-white">No applications yet</p>
        <p class="mt-2">Add an application to this project to begin defining an app-centric workflow.</p>
        <% if can_initiate_build_for_project?(@project) %>
          <div class="mt-6">
            <%= link_to "Add application", new_project_application_path(@project), class: "rounded-full bg-fuchsia-600 px-5 py-2.5 text-sm font-medium text-white transition hover:bg-fuchsia-500" %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</section>

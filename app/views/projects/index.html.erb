<section class="space-y-8">
  <div class="flex flex-wrap items-end justify-between gap-4">
    <div>
      <span class="inline-flex rounded-full border border-fuchsia-200 bg-fuchsia-100 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-700 dark:border-fuchsia-400/20 dark:bg-fuchsia-500/10 dark:text-fuchsia-200">Projects</span>
      <h1 class="mt-4 text-4xl font-semibold tracking-tight text-slate-900 dark:text-white">Choose a project</h1>
      <p class="mt-3 max-w-2xl text-base leading-7 text-slate-600 dark:text-slate-300">Create a project, then add applications inside it.</p>
    </div>

    <div class="flex flex-wrap gap-3">
      <%= link_to "Create project", new_project_path, class: "rounded-full bg-fuchsia-600 px-5 py-2.5 text-sm font-medium text-white transition hover:bg-fuchsia-500" %>
    </div>
  </div>

  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
    <% @projects.each do |project| %>
      <article class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm dark:border-white/10 dark:bg-slate-900/70">
        <div class="flex items-start justify-between gap-3">
          <h2 class="text-xl font-semibold text-slate-900 dark:text-white"><%= link_to project.name, project_path(project), class: "transition hover:text-fuchsia-700 dark:hover:text-fuchsia-200" %></h2>
          <span class="inline-flex rounded-full border px-3 py-1 text-xs font-medium <%= project_summary_state_classes(project) %>"><%= project_summary_state(project) %></span>
        </div>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-300"><%= project.description.presence || "No description yet" %></p>
        <p class="mt-4 text-xs uppercase tracking-wide text-slate-500 dark:text-slate-400">Applications: <span class="font-semibold text-slate-700 dark:text-slate-200"><%= project.applications.count %></span></p>

        <div class="mt-6 flex flex-wrap gap-3">
          <%= link_to "View project", project_path(project), class: "rounded-full border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-100 dark:border-white/10 dark:text-slate-200 dark:hover:bg-white/10" %>
          <%= link_to "Create application", new_project_application_path(project), class: "rounded-full bg-fuchsia-600 px-4 py-2 text-sm font-medium text-white transition hover:bg-fuchsia-500" %>
        </div>
      </article>
    <% end %>
  </div>

  <% if @projects.empty? %>
    <div class="rounded-3xl border border-dashed border-slate-300 bg-white p-10 text-center text-slate-600 dark:border-white/20 dark:bg-slate-900/60 dark:text-slate-300">
      <p class="text-lg font-medium text-slate-900 dark:text-white">No projects yet</p>
      <p class="mt-2">Create your first project to begin organizing applications.</p>
    </div>
  <% end %>
</section>

<section class="space-y-6">
  <div class="rounded-3xl bg-gradient-to-r from-fuchsia-600 to-indigo-600 px-6 py-6 text-white shadow-xl shadow-fuchsia-900/20 sm:px-8">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-100">Dashboard</p>
        <h1 class="mt-2 text-3xl font-semibold tracking-tight sm:text-4xl">All Projects</h1>
        <p class="mt-2 max-w-2xl text-sm text-fuchsia-100">Welcome back, <%= current_user.name %>. Track project health, applications, and recent platform activity.</p>
      </div>
      <div class="rounded-full border border-white/30 bg-white/15 px-4 py-2 text-sm">Operational</div>
    </div>
  </div>

  <div class="rounded-2xl border border-slate-200 bg-white p-1 text-sm shadow-sm dark:border-white/10 dark:bg-slate-900/70">
    <nav class="flex flex-wrap gap-1">
      <a href="#" class="rounded-xl bg-fuchsia-100 px-4 py-2 font-medium text-fuchsia-700 dark:bg-fuchsia-500/15 dark:text-fuchsia-200">Overview</a>
      <a href="#" class="rounded-xl px-4 py-2 text-slate-500 hover:bg-slate-100 hover:text-slate-700 dark:text-slate-400 dark:hover:bg-white/10 dark:hover:text-slate-200">Projects</a>
      <a href="#" class="rounded-xl px-4 py-2 text-slate-500 hover:bg-slate-100 hover:text-slate-700 dark:text-slate-400 dark:hover:bg-white/10 dark:hover:text-slate-200">Activity</a>
      <a href="#" class="rounded-xl px-4 py-2 text-slate-500 hover:bg-slate-100 hover:text-slate-700 dark:text-slate-400 dark:hover:bg-white/10 dark:hover:text-slate-200">Insights</a>
    </nav>
  </div>

  <% if @projects.any? %>
    <div class="grid gap-6 xl:grid-cols-[1fr_21rem]">
      <div class="rounded-3xl border border-slate-200 bg-white shadow-sm dark:border-white/10 dark:bg-slate-900/70">
        <div class="flex flex-wrap items-center gap-3 border-b border-slate-200 px-5 py-4 text-sm dark:border-white/10">
          <span class="rounded-lg border border-slate-200 bg-slate-50 px-3 py-1.5 text-slate-600 dark:border-white/10 dark:bg-white/5 dark:text-slate-300">Everyone’s projects</span>
          <span class="rounded-lg border border-slate-200 bg-slate-50 px-3 py-1.5 text-slate-600 dark:border-white/10 dark:bg-white/5 dark:text-slate-300">All apps</span>
          <span class="rounded-lg border border-slate-200 bg-slate-50 px-3 py-1.5 text-slate-600 dark:border-white/10 dark:bg-white/5 dark:text-slate-300">Last 7 days</span>
        </div>

        <div class="overflow-x-auto">
          <table class="min-w-full text-left text-sm">
            <thead class="border-b border-slate-200 text-xs uppercase tracking-wide text-slate-500 dark:border-white/10 dark:text-slate-400">
              <tr>
                <th class="px-5 py-3 font-semibold">Project</th>
                <th class="px-5 py-3 font-semibold">Applications</th>
                <th class="px-5 py-3 font-semibold">Status</th>
                <th class="px-5 py-3 font-semibold">Slug</th>
                <th class="px-5 py-3 font-semibold text-right">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-200 dark:divide-white/10">
              <% @projects.each do |project| %>
                <tr class="hover:bg-slate-50/80 dark:hover:bg-white/5">
                  <td class="px-5 py-4">
                    <%= link_to project.name, project_path(project), class: "font-semibold text-slate-900 hover:text-fuchsia-700 dark:text-white dark:hover:text-fuchsia-200" %>
                    <% if project.description.present? %>
                      <p class="mt-1 text-xs text-slate-500 dark:text-slate-400"><%= truncate(project.description, length: 70) %></p>
                    <% end %>
                  </td>
                  <td class="px-5 py-4 font-medium text-slate-700 dark:text-slate-200"><%= project.applications.size %></td>
                  <td class="px-5 py-4"><span class="inline-flex rounded-full border px-3 py-1 text-xs font-medium <%= project_summary_state_classes(project) %>"><%= project_summary_state(project) %></span></td>
                  <td class="px-5 py-4 text-slate-500 dark:text-slate-400"><%= project.slug %></td>
                  <td class="px-5 py-4 text-right">
                    <div class="inline-flex gap-2">
                      <%= link_to "Open", project_path(project), class: "rounded-full border border-slate-300 px-3 py-1.5 text-xs font-medium text-slate-700 hover:bg-slate-100 dark:border-white/10 dark:text-slate-200 dark:hover:bg-white/10" %>
                      <%= link_to "Create application", new_project_application_path(project), class: "rounded-full bg-fuchsia-600 px-3 py-1.5 text-xs font-medium text-white hover:bg-fuchsia-500" %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>

      <aside class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm dark:border-white/10 dark:bg-slate-900/70">
        <div class="flex items-center justify-between">
          <h2 class="text-sm font-semibold uppercase tracking-[0.16em] text-slate-500 dark:text-slate-400">Latest activity</h2>
          <span class="text-xs text-fuchsia-600 dark:text-fuchsia-300">All Activity</span>
        </div>
        <ol class="mt-4 space-y-4">
          <% @projects.first(5).each do |project| %>
            <li class="flex gap-3">
              <span class="mt-1 h-2.5 w-2.5 rounded-full bg-fuchsia-500"></span>
              <div>
                <p class="text-sm text-slate-700 dark:text-slate-200"><span class="font-semibold"><%= project.name %></span> updated</p>
                <p class="text-xs text-slate-500 dark:text-slate-400"><%= time_ago_in_words(project.updated_at) %> ago</p>
              </div>
            </li>
          <% end %>
        </ol>
      </aside>
    </div>
  <% else %>
    <div class="rounded-3xl border border-dashed border-slate-300 bg-white p-10 text-center dark:border-white/20 dark:bg-slate-900/60">
      <p class="text-lg font-semibold text-slate-900 dark:text-white">No projects yet</p>
      <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">Create a project to begin managing applications.</p>
      <div class="mt-6">
        <%= link_to "Create project", new_project_path, class: "rounded-full bg-fuchsia-600 px-5 py-2.5 text-sm font-medium text-white transition hover:bg-fuchsia-500" %>
      </div>
    </div>
  <% end %>
</section>
